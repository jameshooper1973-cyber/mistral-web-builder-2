# Add both of these in Vercel: Project Settings > Environment Variables

# Your Mistral API key (from console.mistral.ai)
MISTRAL_API_KEY=your_mistral_api_key_here

# Generated automatically by Vercel when you enable Blob Storage
# Go to: Vercel project > Storage tab > Create Blob Store > it adds this automatically
BLOB_READ_WRITE_TOKEN=your_blob_token_here
